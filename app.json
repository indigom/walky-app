{
  "expo": {
    "name": "walky-app",
    "slug": "walky-app",
    "scheme": "walkyapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.walkyapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.walkyapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/dog_bark.wav"
          ],
          "mode": "production"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "산책 중 이동 거리를 재하고, 근처에 같은 앱을 쓰는 산책자가 있을 때 알려드리기 위해 위치 정보를 사용합니다."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "만보기(걸음 수) 측정을 위해 동작 및 피트니스 정보에 접근합니다."
        }
      ]
    ]
  }
}
