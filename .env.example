# === PC 개발용 (.env 로 복사: copy .env.example .env) ===

# 견종 영상·manifest (가비아 웹호스팅 FTP → walky.co.kr/dogs/)
EXPO_PUBLIC_WALKY_ORIGIN=https://walky.co.kr

# 근처 산책 API — 가비아 웹호스팅(Node 불가)이면 Railway 등에 server/ 배포 후 URL 입력
# 예: Railway Generate Domain 뒤에 /api/nearby/presence
EXPO_PUBLIC_NEARBY_WALKER_API_URL=https://walky-app-production-ace0.up.railway.app/api/nearby/presence
# 노크·대화 (보통 presence와 같은 호스트)
EXPO_PUBLIC_NEARBY_SOCIAL_API_URL=https://walky-app-production-ace0.up.railway.app/api/nearby/social

# 프로필 (닉네임·메타) — Railway
EXPO_PUBLIC_PROFILE_API_URL=https://walky-app-production-ace0.up.railway.app/api/profile

# (선택) 가비아 SFTP 차단 시 — 사진만 가비아 HTTPS로 직접 업로드 (server/deploy/README-PROFILE-STORAGE.md)
# EXPO_PUBLIC_PROFILE_UPLOAD_URL=https://walky.co.kr/api/profile-upload
# EXPO_PUBLIC_PROFILE_UPLOAD_KEY=가비아_UPLOAD_API_KEY와_동일

# 가비아에 Node/VPS가 있어 같은 도메인으로 API까지 쓸 때만:
# EXPO_PUBLIC_NEARBY_WALKER_API_URL=https://walky.co.kr/api/nearby/presence

# 로컬에서 API만 테스트 (실기기·같은 Wi-Fi):
# EXPO_PUBLIC_NEARBY_WALKER_API_URL=http://192.168.0.10:3001/api/nearby/presence
