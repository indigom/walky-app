# Railway Variables (서비스 → Variables). 로컬 테스트 시 server/.env 로 복사.

# --- 가비아 SFTP (프로필 사진 업로드) ---
SFTP_HOST=walky.co.kr
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
# SFTP_PRIVATE_KEY=   # 비밀번호 대신 키 사용 시
# 가비아: SFTP 접속 시 보이는 웹 루트 기준 (절대경로 /www 가 안 되면 www/profiles)
SFTP_REMOTE_DIR=www/profiles
PROFILE_PUBLIC_BASE_URL=https://walky.co.kr/profiles

# --- 운영자 목록 API (선택) ---
ADMIN_API_KEY=

PORT=3001
