# Railway Variables (서비스 → Variables). 로컬 테스트 시 server/.env 로 복사.

# --- 가비아 SFTP (프로필 사진 업로드) ---
# 가비아 SSH 안내 IP 사용 (도메인 walky.co.kr 이 SFTP에 안 될 수 있음)
SFTP_HOST=211.47.74.48
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
# SFTP_PRIVATE_KEY=   # 비밀번호 대신 키 사용 시
# FileZilla에서 profiles 폴더의 경로 그대로 (예: www_root/profiles)
SFTP_REMOTE_DIR=www_root/profiles
PROFILE_PUBLIC_BASE_URL=https://walky.co.kr/profiles

# 진단: curl -H "x-walky-admin-key: KEY" https://YOUR-RAILWAY.up.railway.app/api/admin/sftp-test
ADMIN_API_KEY=

PORT=3001
